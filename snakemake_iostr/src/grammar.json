{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "snakemake_iostr",
  "rules": {
    "source": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "wildcard"
          },
          {
            "type": "SYMBOL",
            "name": "escaped_brace"
          },
          {
            "type": "SYMBOL",
            "name": "text"
          }
        ]
      }
    },
    "wildcard": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "name"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "STRING",
                      "value": ","
                    },
                    {
                      "type": "FIELD",
                      "name": "constraint",
                      "content": {
                        "type": "SYMBOL",
                        "name": "constraint"
                      }
                    }
                  ]
                },
                {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "STRING",
                      "value": ":"
                    },
                    {
                      "type": "FIELD",
                      "name": "flag",
                      "content": {
                        "type": "SYMBOL",
                        "name": "flag"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "escaped_brace": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "{{"
        },
        {
          "type": "STRING",
          "value": "}}"
        }
      ]
    },
    "name": {
      "type": "PATTERN",
      "value": "[a-zA-Z_]\\w*(?:\\.[a-zA-Z_]\\w*|\\[\\d+\\])*"
    },
    "constraint": {
      "type": "PATTERN",
      "value": "(?:[^{}]|\\{\\d+\\})+"
    },
    "flag": {
      "type": "PATTERN",
      "value": "\\w+"
    },
    "text": {
      "type": "PATTERN",
      "value": "[^{}]+"
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}