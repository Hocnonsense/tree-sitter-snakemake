#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
LOCAL_ROOT="$ROOT/.nvim-local"

export XDG_CONFIG_HOME="$LOCAL_ROOT/xdg/config"  # init.lua
export XDG_DATA_HOME="$LOCAL_ROOT/xdg/data"  # nvim/site/parser
# export XDG_STATE_HOME="$LOCAL_ROOT/xdg/state"
# export XDG_CACHE_HOME="$LOCAL_ROOT/xdg/cache"

mkdir -p "$XDG_CONFIG_HOME" "$XDG_DATA_HOME"
# mkdir -p "$XDG_STATE_HOME" "$XDG_CACHE_HOME"

NVIM_BIN="$ROOT/.pixi/envs/nvim/bin/nvim"

exec "$NVIM_BIN" "$@"
